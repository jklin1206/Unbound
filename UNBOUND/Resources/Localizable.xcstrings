    "scan.narrative.first.balanced" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your arc begins balanced across every axis. No single specialty yet — that's a starting line, not a verdict. Come back in 30 days and we'll see where you've tilted."}}}},
    "scan.narrative.first.hybridAthlete" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your arc begins as a hybrid athlete — multiple strengths, no single specialty. The next 30 days of training will start sharpening the lines."}}}},
    "scan.narrative.first.specialist" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your arc begins tilted toward %@. That's where you walked in — now we'll see how it compounds with training. Come back in 30 days."}}}},
    "scan.narrative.first.hybrid.withSecondary" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your arc begins as a %@ hybrid with strong %@. Two strengths to lean into, room everywhere else. The next checkpoint shows what 30 days does."}}}},
    "scan.narrative.first.hybrid.withoutSecondary" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your arc begins as a %@ hybrid. Two strengths to lean into, room everywhere else. The next checkpoint shows what 30 days does."}}}},
    "scan.narrative.first.lean" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your arc begins trending %@. A clear direction, but plenty of room to grow elsewhere. Come back in 30 days."}}}},
    "scan.narrative.evolution.steady" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your build held steady this month. Consistency is its own kind of win — keep the work going and the next checkpoint will show more."}}}},
    "scan.narrative.evolution.primaryWithSecondary" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your %@ grew +%d over the last month. %@ climbed +%d alongside it. The arc is compounding — keep training and the next checkpoint will keep moving."}}}},
    "scan.narrative.evolution.primaryOnly" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your %@ grew +%d over the last month. The arc is compounding — keep training and the next checkpoint will keep moving."}}}},
    "scan.narrative.evolution.moved" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your build moved this month. Keep training — the next checkpoint will show more."}}}},
    "scan.payoffFlavor.fallback" : {"comment":"Deterministic scan narrative fallback text.","localizations":{"en":{"stringUnit":{"state":"translated","value":"Your work is showing."}}}},
